<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
      Name="S3 Browser Cross Platform"
      Manufacturer="S3 Browser Cross Platform"
      Version="{{VERSION}}"
      UpgradeCode="A9D78739-1FB3-4514-9A77-91BDB25CFC39"
      Scope="perMachine"
      Language="1033">
    <SummaryInformation
        Description="Cross-platform S3 browser with pluggable backend engines"
        Manufacturer="S3 Browser Cross Platform" />
    <MediaTemplate EmbedCab="yes" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of S3 Browser Cross Platform is already installed." />
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="S3 Browser Cross Platform">
{{DIRECTORY_TREE}}
      </Directory>
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuDir" Name="S3 Browser Cross Platform" />
    </StandardDirectory>
    <StandardDirectory Id="DesktopFolder" />
    <Feature Id="MainFeature" Title="S3 Browser Cross Platform" Level="1" AllowAbsent="no">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="ShortcutComponents" />
    </Feature>
  </Package>

  <Fragment>
    <ComponentGroup Id="AppFiles">
{{COMPONENTS}}
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ShortcutComponents">
      <Component Id="ApplicationShortcutComponent" Directory="ProgramMenuDir" Guid="*">
        <Shortcut
            Id="ApplicationStartMenuShortcut"
            Name="S3 Browser Cross Platform"
            Target="[INSTALLFOLDER]s3_browser_crossplat.exe"
            WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="ProgramMenuDir" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\S3BrowserCrossplat" Name="installed" Type="integer" Value="1" KeyPath="yes" />
      </Component>
      <Component Id="DesktopShortcutComponent" Directory="DesktopFolder" Guid="*">
        <Shortcut
            Id="ApplicationDesktopShortcut"
            Name="S3 Browser Cross Platform"
            Target="[INSTALLFOLDER]s3_browser_crossplat.exe"
            WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU" Key="Software\S3BrowserCrossplat" Name="desktop" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
